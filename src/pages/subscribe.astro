---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import ShortcutBar from "../components/ShortcutBar.astro";
import Footer from "../components/Footer.astro";

const title = "AI Daily Dev — Subscribe";
const description = "Get the weekly AI developer news roundup in your inbox every Friday.";
---

<Base title={title} description={description}>
  <Header />
  <ShortcutBar />

  <main class="px-6 py-12 max-w-md mx-auto">
    <h1 class="text-2xl font-bold text-[var(--color-story-title)] tracking-tight mb-3">Weekly Roundup</h1>
    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-8">
      The top AI developer stories of the week, delivered to your inbox every Friday morning. No spam, unsubscribe anytime.
    </p>

    <div id="subscribe-form">
      <iframe hidden name="buttondown-frame"></iframe>
      <form
        action="https://buttondown.com/api/emails/embed-subscribe/tordar"
        method="post"
        target="buttondown-frame"
        class="flex flex-col gap-3"
        id="bd-form"
      >
        <input
          type="email"
          name="email"
          placeholder="you@example.com"
          required
          class="bg-[var(--color-bg)] border border-[var(--color-border-section)] text-[var(--color-text)] px-4 py-3 rounded-sm text-sm focus:outline-none focus:border-[var(--color-accent)] transition-colors placeholder:text-[var(--color-text-muted)]"
        />
        <button
          type="submit"
          id="subscribe-btn"
          class="bg-[var(--color-accent)] text-[var(--color-bg)] font-semibold text-sm px-4 py-3 rounded-sm hover:opacity-90 transition-opacity cursor-pointer tracking-wide"
        >
          Subscribe
        </button>
      </form>
    </div>

    <p id="subscribe-success" class="hidden text-sm text-[var(--color-accent)] mt-4 font-medium">
      Thanks! Check your inbox to confirm your subscription.
    </p>
  </main>

  <Footer />
</Base>

<script is:inline>
  document.addEventListener('submit', function(e) {
    var form = e.target.closest('#bd-form');
    if (!form) return;
    var btn = document.getElementById('subscribe-btn');
    var formDiv = document.getElementById('subscribe-form');
    var success = document.getElementById('subscribe-success');
    if (btn) btn.textContent = 'Subscribing...';
    setTimeout(function() {
      if (formDiv) formDiv.classList.add('hidden');
      if (success) success.classList.remove('hidden');
    }, 1000);
  });
</script>
