---
import { getCollection } from "astro:content";
import { groupByWeek } from "../../lib/weeks";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import ShortcutBar from "../../components/ShortcutBar.astro";
import StoryCard from "../../components/StoryCard.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const digests = await getCollection("digests");
  const weekMap = groupByWeek(digests);
  const sorted = Object.keys(weekMap).sort();
  return sorted.map((w, i) => ({
    params: { week: w },
    props: {
      week: w,
      weekEntries: weekMap[w],
      prevWeek: sorted[i - 1] ?? null,
      nextWeek: sorted[i + 1] ?? null,
    },
  }));
}

const { week, weekEntries, prevWeek, nextWeek } = Astro.props;
const allStories = weekEntries.flatMap((e: any) => e.data.stories);
allStories.sort((a: any, b: any) => b.significance - a.significance);
const topStories = allStories.slice(0, 10);
const weekNum = Number(week.split("-W")[1]);
---

<Base title={`Curious AI Daily — Week ${weekNum}`}>
  <Header />
  <ShortcutBar navLabel="change week" />
  <div class="flex items-center justify-between border-b border-[var(--color-border)] py-5 px-6">
    <div class="w-16">
      {prevWeek ? (
        <a href={`/weekly/${prevWeek}`} data-nav="prev" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors text-xl no-underline">&larr;</a>
      ) : (
        <span class="text-[var(--color-text-muted)]/30 text-xl cursor-default select-none">&larr;</span>
      )}
    </div>
    <div class="text-center">
      <div class="uppercase text-xs tracking-widest text-[var(--color-text-muted)] mb-0.5">Weekly Rollup</div>
      <div class="text-xl font-semibold text-[var(--color-text)] tracking-tight">Week {weekNum}</div>
    </div>
    <div class="w-16 text-right">
      {nextWeek ? (
        <a href={`/weekly/${nextWeek}`} data-nav="next" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors text-xl no-underline">&rarr;</a>
      ) : (
        <span class="text-[var(--color-text-muted)]/30 text-xl cursor-default select-none">&rarr;</span>
      )}
    </div>
  </div>
  <main class="px-5 py-6">
    {topStories.map((story: any, idx: number) => (
      <StoryCard story={story} index={idx + 1} />
    ))}
  </main>
  <Footer />
</Base>
