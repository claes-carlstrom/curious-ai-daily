---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import ShortcutBar from "../../components/ShortcutBar.astro";
import StoryCard from "../../components/StoryCard.astro";
import Footer from "../../components/Footer.astro";

function formatMonthLabel(yyyyMM: string): string {
  const [year, month] = yyyyMM.split("-");
  const d = new Date(Number(year), Number(month) - 1, 1);
  return d.toLocaleDateString("en-US", { month: "long", year: "numeric" });
}

export async function getStaticPaths() {
  const digests = await getCollection("digests");
  const monthMap: Record<string, any[]> = {};

  for (const entry of digests) {
    const month = entry.data.date.slice(0, 7);
    if (!monthMap[month]) monthMap[month] = [];
    monthMap[month].push(entry);
  }

  const sortedMonths = Object.keys(monthMap).sort();

  return sortedMonths.map((month, idx) => ({
    params: { month },
    props: {
      month,
      entries: monthMap[month],
      prevMonth: sortedMonths[idx - 1] ?? null,
      nextMonth: sortedMonths[idx + 1] ?? null,
    },
  }));
}

const { month, entries, prevMonth, nextMonth } = Astro.props;

const allStories = entries.flatMap((entry: any) => entry.data.stories);
const topStories = allStories
  .sort((a: any, b: any) => b.significance - a.significance)
  .slice(0, 10);

const monthLabel = formatMonthLabel(month);
const title = `Curious AI Daily — ${monthLabel}`;
const description = topStories.length > 1
  ? `Top stories: ${topStories[0].title}, ${topStories[1].title}.`
  : "Monthly rollup.";
---

<Base title={title} description={description}>
  <Header />
  <ShortcutBar navLabel="change month" />

  <div class="flex items-center justify-between border-b border-[var(--color-border)] py-5 px-6">
    <div class="w-16">
      {prevMonth ? (
        <a href={`/monthly/${prevMonth}`} data-nav="prev" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors text-xl no-underline">←</a>
      ) : (
        <span class="text-[var(--color-text-muted)]/30 text-xl cursor-default select-none">←</span>
      )}
    </div>
    <div class="text-center">
      <div class="uppercase text-xs tracking-widest text-[var(--color-text-muted)] mb-0.5">Monthly Rollup</div>
      <div class="text-xl font-semibold text-[var(--color-text)] tracking-tight">{monthLabel}</div>
    </div>
    <div class="w-16 text-right">
      {nextMonth ? (
        <a href={`/monthly/${nextMonth}`} data-nav="next" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors text-xl no-underline">→</a>
      ) : (
        <span class="text-[var(--color-text-muted)]/30 text-xl cursor-default select-none">→</span>
      )}
    </div>
  </div>

  <main class="px-5 py-6">
    {topStories.map((story: any, idx: number) => (
      <StoryCard story={story} index={idx + 1} />
    ))}
  </main>

  <Footer />
</Base>
