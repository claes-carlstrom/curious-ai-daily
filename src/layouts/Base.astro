---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Analytics from "@vercel/analytics/astro";

interface Story {
  title: string;
  summary: string;
  url: string;
  source: string;
  tag: string;
  significance: number;
}

interface Props {
  title: string;
  description?: string;
  digestDate?: string;
  stories?: Story[];
}

const { title, description = "AI tools, vibecoding, and content creation news curated daily.", digestDate, stories } = Astro.props;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Curious AI Daily",
  "url": Astro.site?.toString() ?? "",
  "description": "AI tools, vibecoding, and content creation news curated daily.",
  "inLanguage": "en",
};

const itemListSchema = stories?.length ? {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": title,
  "itemListElement": stories.map((s, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": s.title,
    "url": s.url,
  })),
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    {digestDate && <meta property="og:image" content={`${Astro.site}og/${digestDate}.png`} />}
    {digestDate && <meta property="og:image:width" content="1200" />}
    {digestDate && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content={digestDate ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {digestDate && <meta name="twitter:image" content={`${Astro.site}og/${digestDate}.png`} />}

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Curious AI Daily" href="/feed.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {itemListSchema && <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />}
    <ClientRouter />
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') document.documentElement.classList.add('light');
    </script>
  </head>
  <body data-digest-date={digestDate}>
    <div class="max-w-[860px] mx-auto">
      <slot />
    </div>
    <script src="../scripts/keyboard.ts"></script>
    <Analytics />

    <!-- Commentary side panel (global, shared across all story cards) -->
    <div
      id="commentary-overlay"
      class="fixed inset-0 z-40 hidden"
      style="background: rgba(0,0,0,0.45);"
    ></div>
    <aside
      id="commentary-panel"
      class="fixed top-0 right-0 h-full z-50 flex flex-col"
      style="width: 380px; max-width: 92vw; background: var(--color-bg); border-left: 1px solid var(--color-border-section); transform: translateX(100%); transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);"
      aria-hidden="true"
    >
      <div class="flex items-center justify-between px-5 py-4 shrink-0" style="border-bottom: 1px solid var(--color-border-section);">
        <span id="commentary-panel-label" class="text-[11px] font-semibold uppercase tracking-widest"></span>
        <button
          id="commentary-panel-close"
          class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] text-2xl leading-none transition-colors cursor-pointer"
          aria-label="Close"
        >×</button>
      </div>
      <div class="flex-1 overflow-y-auto px-5 pt-5 pb-8 flex flex-col gap-4">
        <p id="commentary-panel-title" class="text-[12px] text-[var(--color-text-muted)] leading-snug"></p>
        <p id="commentary-panel-body" class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed"></p>
      </div>
    </aside>
  </body>
</html>
