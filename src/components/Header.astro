---
import { getCollection } from "astro:content";
import { getISOWeek } from "../lib/weeks";

const digests = await getCollection("digests");
const sorted = digests.sort((a, b) => b.data.date.localeCompare(a.data.date));
const latestDate = sorted[0]?.data.date ?? "";
const latestWeek = latestDate ? getISOWeek(latestDate) : "";
const latestMonth = latestDate ? latestDate.slice(0, 7) : "";
---

<header class="flex items-center justify-between border-b border-[var(--color-border-section)] py-4 px-5">
  <a href="/" class="flex items-baseline gap-0 no-underline">
    <span class="text-[var(--color-accent)] font-bold tracking-tight text-base">AI DAILY</span>
    <span class="text-[var(--color-text-muted)] font-light text-base"> / DEV</span>
  </a>
  <nav class="flex items-center gap-5">
    <a href="/archive" class="uppercase text-[10px] tracking-widest text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors no-underline">archive</a>
    <a href={`/weekly/${latestWeek}`} class="uppercase text-[10px] tracking-widest text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors no-underline">weekly</a>
    <a href={`/monthly/${latestMonth}`} class="uppercase text-[10px] tracking-widest text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors no-underline">monthly</a>
  </nav>
</header>
