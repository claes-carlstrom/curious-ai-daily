---
import { getCollection } from "astro:content";
import { getISOWeek } from "../lib/weeks";

const digests = await getCollection("digests");
const sorted = digests.sort((a, b) => b.data.date.localeCompare(a.data.date));
const latestDate = sorted[0]?.data.date ?? "";
const latestWeek = latestDate ? getISOWeek(latestDate) : "";
const latestMonth = latestDate ? latestDate.slice(0, 7) : "";
---

<header class="flex flex-wrap items-center gap-x-6 gap-y-3 border-b border-[var(--color-border-section)] py-4 px-5">
  <a href="/" class="flex items-center no-underline mr-auto" aria-label="Curious Mind — home">
    <!-- White logo for dark mode, black logo for light mode -->
    <img
      src="/brand/logo-white.png"
      alt="Curious Mind"
      class="h-7 w-auto dark-logo"
      style="display: none;"
    />
    <img
      src="/brand/logo-black.png"
      alt="Curious Mind"
      class="h-7 w-auto light-logo"
      style="display: block;"
    />
  </a>
  <nav class="flex items-center justify-center gap-4 md:gap-6 order-last md:order-none w-full md:w-auto">
    <a href="/" class="uppercase text-[11px] tracking-widest text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors no-underline">daily</a>
    <a href={`/weekly/${latestWeek}`} class="uppercase text-[11px] tracking-widest text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors no-underline">weekly</a>
    <a href={`/monthly/${latestMonth}`} class="uppercase text-[11px] tracking-widest text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors no-underline">monthly</a>
    <a href="/archive" class="uppercase text-[11px] tracking-widest text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors no-underline">archive</a>
    <a href="/subscribe" class="uppercase text-[11px] tracking-widest text-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors no-underline">subscribe</a>
  </nav>
  <div class="flex items-center gap-3">
    <a
      href="/settings"
      class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors text-sm no-underline"
      aria-label="Settings"
      title="Sources settings"
    >&#9881;</a>
    <button
      id="theme-toggle"
      class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors text-sm cursor-pointer"
      aria-label="Toggle theme"
      title="Toggle theme (t)"
    >
      <span id="theme-icon-dark" class="hidden">&#9788;</span>
      <span id="theme-icon-light">&#9790;</span>
    </button>
  </div>
</header>

<script is:inline>
  function applyLogoTheme(isLight) {
    var darkLogos = document.querySelectorAll('.dark-logo');
    var lightLogos = document.querySelectorAll('.light-logo');
    darkLogos.forEach(function(el) { el.style.display = isLight ? 'none' : 'block'; });
    lightLogos.forEach(function(el) { el.style.display = isLight ? 'block' : 'none'; });
  }

  document.addEventListener('click', function(e) {
    var btn = e.target.closest('#theme-toggle');
    if (!btn) return;
    var isDark = !document.documentElement.classList.contains('dark');
    document.documentElement.classList.toggle('dark', isDark);
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    var dark = document.getElementById('theme-icon-dark');
    var light = document.getElementById('theme-icon-light');
    if (dark) dark.classList.toggle('hidden', isDark);
    if (light) light.classList.toggle('hidden', !isDark);
    applyLogoTheme(!isDark);
  });

  function syncThemeIcons() {
    var isDark = document.documentElement.classList.contains('dark');
    var dark = document.getElementById('theme-icon-dark');
    var light = document.getElementById('theme-icon-light');
    if (dark) dark.classList.toggle('hidden', isDark);
    if (light) light.classList.toggle('hidden', !isDark);
    applyLogoTheme(!isDark);
  }
  syncThemeIcons();
  document.addEventListener('astro:page-load', syncThemeIcons);
</script>
