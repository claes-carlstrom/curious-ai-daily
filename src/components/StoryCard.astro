---
interface Story {
  title: string;
  summary: string;
  url: string;
  source: string;
  tag: string;
  significance: number;
}

interface Props {
  index: number;
  story: Story;
}

const { index, story } = Astro.props;
const { title, summary, url, source, tag } = story;

const indexFormatted = String(index).padStart(2, "0");
const cardId = `story-${index}`;

const tagStyles: Record<string, { bg: string; text: string }> = {
  models: { bg: "var(--color-tag-models-bg)", text: "var(--color-tag-models)" },
  tools: { bg: "var(--color-tag-tools-bg)", text: "var(--color-tag-tools)" },
  vibecoding: { bg: "var(--color-tag-vibecoding-bg)", text: "var(--color-tag-vibecoding)" },
  "content-creation": { bg: "var(--color-tag-content-creation-bg)", text: "var(--color-tag-content-creation)" },
  marketing: { bg: "var(--color-tag-marketing-bg)", text: "var(--color-tag-marketing)" },
  research: { bg: "var(--color-tag-research-bg)", text: "var(--color-tag-research)" },
  "open-source": { bg: "var(--color-tag-open-source-bg)", text: "var(--color-tag-open-source)" },
  community: { bg: "var(--color-tag-community-bg)", text: "var(--color-tag-community)" },
};

const tagStyle = tagStyles[tag] ?? { bg: "transparent", text: "var(--color-text-muted)" };
---

<div
  class="flex gap-4 border-b border-[var(--color-border)]/50 py-5 px-5 cursor-pointer transition-all hover:bg-[var(--color-story-hover)] group"
  data-story-index={index}
  id={cardId}
>
  <div class="hidden md:block shrink-0 w-6 text-right">
    <span class="text-[var(--color-index)] font-bold text-xl leading-none">{indexFormatted}</span>
  </div>
  <div class="flex-1 min-w-0">
    <a href={url} target="_blank" rel="noopener noreferrer" class="no-underline group-hover:underline">
      <h2 class="text-lg font-semibold text-[var(--color-story-title)] tracking-tight leading-snug mb-1.5">{title}</h2>
    </a>
    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-2.5">{summary}</p>

    <!-- Tag row + commentary buttons -->
    <div class="flex items-center justify-between gap-2">
      <div class="flex items-center gap-2">
        <span
          class="uppercase text-[10px] px-2 py-0.5 rounded-sm font-medium tracking-wide"
          style={`background-color: ${tagStyle.bg}; color: ${tagStyle.text};`}
        >
          {tag}
        </span>
        <span class="text-[11px] text-[var(--color-text-muted)]">{source}</span>
      </div>

      <!-- +/- buttons -->
      <div class="flex items-center gap-1 shrink-0">
        <button
          class="commentary-btn w-6 h-6 rounded-full flex items-center justify-center text-[13px] font-bold leading-none transition-all border border-transparent hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] text-[var(--color-text-muted)]"
          data-card={cardId}
          data-type="positive"
          data-title={title}
          data-summary={summary}
          data-source={source}
          data-tag={tag}
          aria-label="Positive take"
          title="What's the opportunity here?"
        >+</button>
        <button
          class="commentary-btn w-6 h-6 rounded-full flex items-center justify-center text-[13px] font-bold leading-none transition-all border border-transparent hover:border-[var(--color-text-muted)] hover:text-[var(--color-text)] text-[var(--color-text-muted)]"
          data-card={cardId}
          data-type="critical"
          data-title={title}
          data-summary={summary}
          data-source={source}
          data-tag={tag}
          aria-label="Critical take"
          title="What's the catch?"
        >−</button>
      </div>
    </div>

    <!-- Commentary panel — appears inline below the tag row -->
    <div
      class="commentary-panel hidden mt-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface,#111)] p-4"
      data-card={cardId}
    >
      <div class="flex items-start justify-between gap-2 mb-2">
        <span class="commentary-panel-label text-[11px] font-semibold uppercase tracking-wide"></span>
        <button
          class="commentary-panel-close text-[var(--color-text-muted)] hover:text-[var(--color-text)] leading-none text-lg shrink-0"
          aria-label="Close"
        >×</button>
      </div>
      <p class="commentary-panel-body text-[13px] text-[var(--color-text-secondary)] leading-relaxed"></p>
    </div>
  </div>
</div>

<script>
  if (!(window as any).__commentaryInit) {
    (window as any).__commentaryInit = true;

    let activePanel: HTMLElement | null = null;
    let activeType: string | null = null;

    function closePanel() {
      if (activePanel) {
        activePanel.classList.add("hidden");
        activePanel = null;
        activeType = null;
      }
    }

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closePanel();
    });

    document.addEventListener("click", async (e) => {
      const btn = (e.target as HTMLElement).closest(".commentary-btn") as HTMLElement | null;

      // Close button inside panel
      if ((e.target as HTMLElement).closest(".commentary-panel-close")) {
        closePanel();
        return;
      }

      if (!btn) {
        // Click outside any button — close panel
        if (activePanel && !(e.target as HTMLElement).closest(".commentary-panel")) {
          closePanel();
        }
        return;
      }

      e.stopPropagation();

      const cardId = btn.dataset.card!;
      const type = btn.dataset.type as "positive" | "critical";
      const card = document.getElementById(cardId);
      if (!card) return;

      const panel = card.querySelector<HTMLElement>(`.commentary-panel[data-card='${cardId}']`);
      if (!panel) return;

      // Toggle off if same button clicked again
      if (activePanel === panel && activeType === type) {
        closePanel();
        return;
      }

      // Close any other open panel
      closePanel();
      activePanel = panel;
      activeType = type;

      const label = panel.querySelector<HTMLElement>(".commentary-panel-label")!;
      const body = panel.querySelector<HTMLElement>(".commentary-panel-body")!;

      if (type === "positive") {
        label.textContent = "💡 Opportunity";
        label.style.color = "var(--color-accent)";
      } else {
        label.textContent = "🔍 Critical take";
        label.style.color = "var(--color-text-muted)";
      }

      body.textContent = "Thinking…";
      panel.classList.remove("hidden");

      try {
        const res = await fetch("/api/commentary", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            title: btn.dataset.title,
            summary: btn.dataset.summary,
            source: btn.dataset.source,
            tag: btn.dataset.tag,
            type,
          }),
        });

        if (!res.ok) {
          const ct = res.headers.get("content-type") ?? "";
          if (ct.includes("application/json")) {
            const err = await res.json();
            body.textContent = err.error ?? "Couldn't generate a take right now — try again in a moment.";
          } else {
            body.textContent = "Couldn't generate a take right now — try again in a moment.";
          }
          return;
        }

        const data = await res.json();
        body.textContent = data.commentary || "No response — try again.";
      } catch {
        body.textContent = "Couldn't reach the server — check your connection.";
      }
    });
  }
</script>
