---
interface Story {
  title: string;
  summary: string;
  url: string;
  source: string;
  tag: string;
  significance: number;
}

interface Props {
  index: number;
  story: Story;
}

const { index, story } = Astro.props;
const { title, summary, url, source, tag } = story;

const indexFormatted = String(index).padStart(2, "0");

const tagStyles: Record<string, { bg: string; text: string }> = {
  models: { bg: "var(--color-tag-models-bg)", text: "var(--color-tag-models)" },
  tools: { bg: "var(--color-tag-tools-bg)", text: "var(--color-tag-tools)" },
  vibecoding: { bg: "var(--color-tag-vibecoding-bg)", text: "var(--color-tag-vibecoding)" },
  "content-creation": { bg: "var(--color-tag-content-creation-bg)", text: "var(--color-tag-content-creation)" },
  marketing: { bg: "var(--color-tag-marketing-bg)", text: "var(--color-tag-marketing)" },
  research: { bg: "var(--color-tag-research-bg)", text: "var(--color-tag-research)" },
  "open-source": { bg: "var(--color-tag-open-source-bg)", text: "var(--color-tag-open-source)" },
  community: { bg: "var(--color-tag-community-bg)", text: "var(--color-tag-community)" },
};

const tagStyle = tagStyles[tag] ?? { bg: "transparent", text: "var(--color-text-muted)" };
---

<div
  class="flex gap-4 border-b border-[var(--color-border)]/50 py-5 px-5 cursor-pointer transition-all hover:bg-[var(--color-story-hover)] group"
  data-story-index={index}
>
  <div class="hidden md:block shrink-0 w-6 text-right">
    <span class="text-[var(--color-index)] font-bold text-xl leading-none">{indexFormatted}</span>
  </div>
  <div class="flex-1 min-w-0">
    <a href={url} target="_blank" rel="noopener noreferrer" class="no-underline group-hover:underline">
      <h2 class="text-lg font-semibold text-[var(--color-story-title)] tracking-tight leading-snug mb-1.5">{title}</h2>
    </a>
    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-2.5">{summary}</p>

    <div class="flex items-center justify-between gap-2">
      <div class="flex items-center gap-2">
        <span
          class="uppercase text-[10px] px-2 py-0.5 rounded-sm font-medium tracking-wide"
          style={`background-color: ${tagStyle.bg}; color: ${tagStyle.text};`}
        >
          {tag}
        </span>
        <span class="text-[11px] text-[var(--color-text-muted)]">{source}</span>
      </div>

      <!-- Commentary bubble buttons -->
      <div class="flex items-center gap-2 shrink-0">
        <!-- + opportunity bubble -->
        <button
          class="commentary-btn transition-colors text-[var(--color-text-muted)] hover:text-[var(--color-accent)] cursor-pointer"
          data-type="positive"
          data-title={title}
          data-summary={summary}
          data-source={source}
          data-tag={tag}
          aria-label="Opportunity take"
          title="What can I do with this?"
        >
          <svg width="26" height="24" viewBox="0 0 26 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="0.75" y="0.75" width="24.5" height="16.5" rx="3.25" stroke="currentColor" stroke-width="1.5"/>
            <path d="M5 17.25 L5 22.5 L10.5 17.25" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <line x1="13" y1="5.5" x2="13" y2="13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="9" y1="9.5" x2="17" y2="9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <!-- − critical bubble -->
        <button
          class="commentary-btn transition-colors text-[var(--color-text-muted)] hover:text-[var(--color-text)] cursor-pointer"
          data-type="critical"
          data-title={title}
          data-summary={summary}
          data-source={source}
          data-tag={tag}
          aria-label="Critical take"
          title="What's the catch?"
        >
          <svg width="26" height="24" viewBox="0 0 26 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="0.75" y="0.75" width="24.5" height="16.5" rx="3.25" stroke="currentColor" stroke-width="1.5"/>
            <path d="M5 17.25 L5 22.5 L10.5 17.25" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <line x1="9" y1="9.5" x2="17" y2="9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  // Single init guard — runs once no matter how many StoryCards are on the page
  if (!(window as any).__commentaryInit) {
    (window as any).__commentaryInit = true;

    const panel     = document.getElementById("commentary-panel")!;
    const overlay   = document.getElementById("commentary-overlay")!;
    const labelEl   = document.getElementById("commentary-panel-label")!;
    const titleEl   = document.getElementById("commentary-panel-title")!;
    const bodyEl    = document.getElementById("commentary-panel-body")!;
    const closeBtn  = document.getElementById("commentary-panel-close")!;

    let currentKey = ""; // "title::type" — tracks what's open so we can toggle

    function openPanel() {
      panel.style.transform = "translateX(0)";
      panel.setAttribute("aria-hidden", "false");
      overlay.classList.remove("hidden");
    }

    function closePanel() {
      panel.style.transform = "translateX(100%)";
      panel.setAttribute("aria-hidden", "true");
      overlay.classList.add("hidden");
      currentKey = "";
    }

    closeBtn.addEventListener("click", closePanel);
    overlay.addEventListener("click", closePanel);
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") closePanel(); });

    document.addEventListener("click", async (e) => {
      const btn = (e.target as HTMLElement).closest(".commentary-btn") as HTMLElement | null;
      if (!btn) return;

      e.stopPropagation();

      const type    = btn.dataset.type as "positive" | "critical";
      const title   = btn.dataset.title!;
      const summary = btn.dataset.summary!;
      const source  = btn.dataset.source!;
      const tag     = btn.dataset.tag!;
      const key     = `${title}::${type}`;

      // Toggle closed if same button clicked again
      if (currentKey === key) {
        closePanel();
        return;
      }

      currentKey = key;

      if (type === "positive") {
        labelEl.textContent = "💡 Opportunity";
        labelEl.style.color = "var(--color-accent)";
      } else {
        labelEl.textContent = "🔍 Critical take";
        labelEl.style.color = "var(--color-text-muted)";
      }

      titleEl.textContent = title;
      bodyEl.textContent  = "Thinking…";
      openPanel();

      try {
        const res = await fetch("/api/commentary", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ title, summary, source, tag, type }),
        });

        if (!res.ok) {
          const ct = res.headers.get("content-type") ?? "";
          const err = ct.includes("application/json") ? await res.json() : {};
          bodyEl.textContent = err.error ?? "Couldn't get a take right now — try again in a moment.";
          return;
        }

        const data = await res.json();
        bodyEl.textContent = data.commentary || "No response — try again.";
      } catch {
        bodyEl.textContent = "Couldn't reach the server.";
      }
    });
  }
</script>
